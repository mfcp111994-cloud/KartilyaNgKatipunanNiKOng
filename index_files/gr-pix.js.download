setCookie("_gr",attrib.gruid,CONFIG.attrMaxAgeDays);}
return attrib;}
function resolveClickServerSide(attrib){if(attrib.grclid)return;if(CONFIG.inAppBrowser)return;var resolveUrl;var creds;if(CONFIG.proxyEndpoint){resolveUrl=CONFIG.proxyEndpoint.replace(/\/$/,"")+"/resolve-click";creds="include";}else{resolveUrl=(CONFIG.eventEndpoint||"").replace(/\/track\/gr-events$/,"/track/resolve-click");if(!resolveUrl||resolveUrl===CONFIG.eventEndpoint)return;creds="omit";}
try{fetch(resolveUrl,{method:"POST",headers:{"Content-Type":"application/json"},body:safeStringify({gruid:attrib.gruid||null,page_url:window.location.href,}),credentials:creds,}).then(function(resp){if(!resp.ok)return;return resp.json();}).then(function(data){if(!data||!data.matched||!data.grclid)return;attrib.grclid=data.grclid;if(data.grcpid)attrib.grcpid=data.grcpid;if(data.grpuid)attrib.grpuid=data.grpuid;if(data.gradid)attrib.gradid=data.gradid;if(data.graid)attrib.graid=data.graid;attrib.last_touch=Date.now();attrib.resolved_server_side=true;try{if(window.localStorage){window.localStorage.setItem(CONFIG.attrStorageKey,safeStringify(attrib));}}catch(_){}}).catch(function(){});}catch(_){}}
function loadSession(currentAttrib){const sessionTimeout=(CONFIG.sessionTimeoutMinutes||30)*60*1000;let session=null;try{if(window.localStorage){var storedSession=window.localStorage.getItem("_gr_session");if(storedSession)session=safeParse(storedSession,null);}}catch(_){}
if(!session)session=safeParse(getCookie(CONFIG.sessionCookie),null);let isNew=false;if(!session||!session.id||typeof session.started_at!=="number"||now-(session.last_seen||0)>sessionTimeout){isNew=true;session={id:uuid("gr_sess_"),started_at:now,last_seen:now,page_views:0,landing_url:truncateString(sanitizeUrl(window.location.href||"")||"",MAX_URL_LENGTH),entry_referrer:truncateString(sanitizeUrl(document.referrer||"")||"",MAX_URL_LENGTH)||null,page_history:[],};}else{session.last_seen=now;session.landing_url=truncateString(sanitizeUrl(session.landing_url||"")||"",MAX_URL_LENGTH);session.entry_referrer=truncateString(sanitizeUrl(session.entry_referrer||"")||"",MAX_URL_LENGTH)||null;}
session.page_views=Number(session.page_views||0)+1;session.last_page_url=truncateString(sanitizeUrl(window.location.href||"")||"",MAX_URL_LENGTH);session.last_page_title=truncateString(document.title||"",MAX_TITLE_LENGTH)||null;session.last_seen=now;session.visitor_id=currentAttrib.gruid;if(CONFIG.captureAdvertiserUserId){const advertiserId=captureAdvertiserUserId();if(advertiserId){session.advertiser_user_id=advertiserId;}}else{delete session.advertiser_user_id;}
const storedSnapshot=session.history_snapshot&&Array.isArray(session.history_snapshot)?session.history_snapshot:Array.isArray(session.page_history)?session.page_history:[];const existingHistory=loadHistory(session.id,storedSnapshot);session.page_history=Array.isArray(existingHistory)?existingHistory.map(function(entry){if(!entry||typeof entry!=="object")return entry;return{url:truncateString(sanitizeUrl(entry.url||"")||"",MAX_URL_LENGTH),title:truncateString(entry.title||"",MAX_TITLE_LENGTH)||null,timestamp:entry.timestamp||null,};}):[];session.page_history.push({url:truncateString(sanitizeUrl(window.location.href||"")||"",MAX_URL_LENGTH),title:truncateString(document.title||"",MAX_TITLE_LENGTH)||null,timestamp:new Date(now).toISOString(),});const maxPages=typeof CONFIG.sessionMaxPages==="number"&&CONFIG.sessionMaxPages>0?CONFIG.sessionMaxPages:50;if(session.page_history.length>maxPages){session.page_history.splice(0,session.page_history.length-maxPages);}
persistSession(session);return{session,isNew};}
function persistSession(session){const history=Array.isArray(session.page_history)?session.page_history:[];persistHistory(session.id,history);var sessionData={id:session.id,started_at:session.started_at,last_seen:session.last_seen,page_views:session.page_views,landing_url:truncateString(session.landing_url||"",MAX_URL_LENGTH),entry_referrer:truncateString(session.entry_referrer||"",MAX_URL_LENGTH)||null,last_page_url:truncateString(session.last_page_url||"",MAX_URL_LENGTH),visitor_id:session.visitor_id||null,advertiser_user_id:session.advertiser_user_id||null,};try{if(window.localStorage){window.localStorage.setItem("_gr_session",safeStringify(sessionData));}}catch(_){}
setCookie(CONFIG.sessionCookie,safeStringify({id:session.id,started_at:session.started_at,last_seen:session.last_seen,}),CONFIG.sessionMaxAgeDays);}
function processCommand(command,args){if(command==="init"&&args&&args.length>0&&typeof args[0]==="string"){pixelId=args[0];}}
function processQueue(){const queueName=window.GravityPixelObject||"gravity";const queue=window[queueName];if(queue&&Array.isArray(queue.q)){for(let i=0;i<queue.q.length;i+=1){const item=queue.q[i];if(item&&item.length>0){const command=item[0];const args=Array.prototype.slice.call(item,1);processCommand(command,args);}}}
const originalFn=window[queueName];if(typeof originalFn==="function"){const newFn=function(){const args=Array.prototype.slice.call(arguments);if(args.length>0){const command=args[0];const commandArgs=args.slice(1);processCommand(command,commandArgs);}
if(originalFn&&typeof originalFn==="function"){return originalFn.apply(this,arguments);}};if(originalFn.q){newFn.q=originalFn.q;}
if(originalFn.l){newFn.l=originalFn.l;}
window[queueName]=newFn;}}
function proxyInit(attrib){if(!CONFIG.proxyEndpoint)return;if(CONFIG.inAppBrowser)return;var initUrl=CONFIG.proxyEndpoint.replace(/\/$/,"")+"/init";var urlParams={};try{var sp=new URLSearchParams(window.location.search);sp.forEach(function(v,k){urlParams[k]=v;});}catch(_){}
try{fetch(initUrl,{method:"POST",headers:{"Content-Type":"application/json"},body:safeStringify({url:window.location.href,referrer:document.referrer||null,params:urlParams,gruid:attrib.gruid||null,}),credentials:"include",}).then(function(resp){if(!resp.ok)return;return resp.json();}).then(function(data){if(!data||!data.attribution)return;var serverAttrib=data.attribution;var keys=["grclid","grcpid","grpuid","gradid","grsig","graid"];for(var i=0;i<keys.length;i++){if(serverAttrib[keys[i]]&&!attrib[keys[i]]){attrib[keys[i]]=serverAttrib[keys[i]];}}
try{if(window.localStorage){window.localStorage.setItem(CONFIG.attrStorageKey,safeStringify(attrib));}}catch(_){}}).catch(function(){});}catch(_){}}
processQueue();const attribution=captureAttribution();proxyInit(attribution);resolveClickServerSide(attribution);const{session,isNew:isNewSession}=loadSession(attribution);function baseEventPayload(){return{event_id:uuid("gr_evt_"),event_timestamp:new Date().toISOString(),session_id:session.id,visitor_id:attribution.gruid,click_id:attribution.grclid||null,pixel_id:pixelId||null,page_url:sanitizeUrl(window.location.href),page_title:document.title||null,referrer:sanitizeUrl(document.referrer)||null,user_agent:navigator.userAgent||null,language:navigator.language||null,screen:{width:window.screen&&window.screen.width,height:window.screen&&window.screen.height,color_depth:window.screen&&window.screen.colorDepth,pixel_depth:window.screen&&window.screen.pixelDepth,},};}
function trackEvent(eventType,metadata){if(!CONFIG.eventEndpoint)return;metadata=metadata||{};const payload=baseEventPayload();payload.event_type=eventType;payload.session_start=isNewSession;metadata.visitor={id:attribution.gruid,click_id:attribution.grclid||null,advertiser_user_id:session.advertiser_user_id||null,};if(CONFIG.inAppBrowser){metadata.pixel_source="publisher_in_app_browser";}
payload.metadata=metadata;payload.attribution=Object.assign({},attribution);postJSON(CONFIG.eventEndpoint,payload);}
function appendSignalValue(parts,value){if(value===null||value===undefined)return;if(Array.isArray(value)){for(let i=0;i<value.length;i++){appendSignalValue(parts,value[i]);}
return;}
if(typeof value==="object")return;const text=String(value).trim();if(text)parts.push(text);}
function appendObjectSignalValues(parts,record){if(!record||typeof record!=="object")return;const keys=Object.keys(record);for(let i=0;i<keys.length;i++){const key=keys[i];appendSignalValue(parts,key);appendSignalValue(parts,record[key]);}}
function normalizeSignalText(parts){if(!Array.isArray(parts)||parts.length===0)return"";return parts.join(" ").toLowerCase().replace(/[_\-]+/g," ").replace(/\s+/g," ").trim();}
function matchesAnyPattern(value,patterns){if(!value)return false;for(let i=0;i<patterns.length;i++){if(patterns[i].test(value))return true;}
return false;}
function normalizeUrlSignal(value){if(!value)return"";try{const url=new URL(String(value),window.location.href);return(url.origin+url.pathname+url.search).toLowerCase();}catch(_){return String(value).toLowerCase();}}
function hasNonEmptySignal(value){if(value===null||value===undefined)return false;if(Array.isArray(value))return value.length>0;if(typeof value==="string")return value.trim()!=="";return true;}
function looksLikeAddToCart(signalText,urlText){const hasAddToCartUrlPattern=/\/cart\/add(?:\.js)?(?:\/|$|\?)/.test(urlText)||/\/cart\/[0-9]+:[0-9]+(?:,[0-9]+:[0-9]+)*(?:\/|$|\?)/.test(urlText)||/[?&](?:add_to_cart|cart_action)=add(?:&|$)/.test(urlText);if(hasAddToCartUrlPattern){return!matchesAnyPattern(urlText,ECOM_ADD_TO_CART_EXCLUDE_PATTERNS);}
if(!matchesAnyPattern(signalText,ECOM_ADD_TO_CART_PATTERNS)){return false;}
return!matchesAnyPattern(signalText,ECOM_ADD_TO_CART_EXCLUDE_PATTERNS);}
function looksLikeBuyNow(signalText,urlText){if(!matchesAnyPattern(signalText,ECOM_BUY_NOW_PATTERNS)){return false;}
if(matchesAnyPattern(urlText,ECOM_CHECKOUT_EXCLUDE_PATTERNS)){return false;}
if(matchesAnyPattern(signalText,ECOM_CHECKOUT_EXCLUDE_PATTERNS)){return false;}
return true;}
function looksLikeCheckoutStart(signalText,urlText){const urlLooksExcluded=matchesAnyPattern(urlText,ECOM_CHECKOUT_EXCLUDE_PATTERNS);if(/\/checkouts?(?:\/|$|\?)/.test(urlText)){return!urlLooksExcluded;}
if(!matchesAnyPattern(signalText,ECOM_CHECKOUT_PATTERNS)){return false;}
return!urlLooksExcluded&&!matchesAnyPattern(signalText,ECOM_CHECKOUT_EXCLUDE_PATTERNS);}
function looksLikeProductViewClick(urlText){return(/\/products?\/[^/?#]+/.test(urlText)||/\/p\/[^/?#]+/.test(urlText)||/\/dp\/[a-z0-9]/.test(urlText));}
function looksLikeContact(rawHref){if(!rawHref)return false;var lower=rawHref.toLowerCase();return/^tel:/.test(lower)||/^mailto:/.test(lower);}
function looksLikeLeadForm(signalText,urlText){if(matchesAnyPattern(signalText,LEAD_FORM_EXCLUDE))return false;if(matchesAnyPattern(signalText,LEAD_FORM_PATTERNS))return true;if(matchesAnyPattern(urlText,LEAD_URL_PATTERNS))return true;return false;}
function looksLikeRegistrationForm(signalText,urlText){if(matchesAnyPattern(signalText,REG_FORM_EXCLUDE))return false;if(matchesAnyPattern(signalText,REG_FORM_PATTERNS))return true;if(matchesAnyPattern(urlText,REG_URL_PATTERNS))return true;return false;}
function looksLikePurchasePageView(urlText){return matchesAnyPattern(urlText,PURCHASE_URL_PATTERNS);}
function inferClickEventType(actionable,metadata,rawHref){if(looksLikeContact(rawHref))return"contact";const signalParts=[];appendSignalValue(signalParts,metadata&&metadata.text);appendSignalValue(signalParts,metadata&&metadata.id);appendSignalValue(signalParts,metadata&&metadata.classes);appendSignalValue(signalParts,metadata&&metadata.role);appendSignalValue(signalParts,actionable&&actionable.name);appendSignalValue(signalParts,actionable&&actionable.value);if(actionable&&typeof actionable.getAttribute==="function"){appendSignalValue(signalParts,actionable.getAttribute("aria-label"));appendSignalValue(signalParts,actionable.getAttribute("title"));appendSignalValue(signalParts,actionable.getAttribute("data-action"));appendSignalValue(signalParts,actionable.getAttribute("data-testid"));appendSignalValue(signalParts,actionable.getAttribute("data-test-id"));}
const signalText=normalizeSignalText(signalParts);const urlText=normalizeUrlSignal(metadata&&metadata.href);if(looksLikeContact(rawHref))return"contact";if(looksLikeCheckoutStart(signalText,urlText))return"checkout_start";if(looksLikeBuyNow(signalText,urlText))return"checkout_start";if(looksLikeAddToCart(signalText,urlText))return"add_to_cart";if(looksLikeProductViewClick(urlText))return"product_view";return"click";}
function inferFormSubmitEventType(formIdentity,submitButton,formData,formActionQuery){const signalParts=[];appendSignalValue(signalParts,formIdentity&&formIdentity.id);appendSignalValue(signalParts,formIdentity&&formIdentity.name);appendSignalValue(signalParts,formIdentity&&formIdentity.class);appendSignalValue(signalParts,submitButton&&submitButton.id);appendSignalValue(signalParts,submitButton&&submitButton.name);appendSignalValue(signalParts,submitButton&&submitButton.value);appendSignalValue(signalParts,submitButton&&submitButton.text);appendObjectSignalValues(signalParts,formActionQuery&&formActionQuery.raw);const signalText=normalizeSignalText(signalParts);const actionText=normalizeUrlSignal(formIdentity&&formIdentity.action);const commerceFields=formData&&formData.commerce_fields?formData.commerce_fields:{};const formType=normalizeSignalText([commerceFields.form_type]);const looksLikeProductForm=formType==="product"||hasNonEmptySignal(commerceFields.variant_id)||hasNonEmptySignal(commerceFields.product_id)||hasNonEmptySignal(commerceFields.sku);if(looksLikeCheckoutStart(signalText,actionText)){return"checkout_start";}
if(looksLikeBuyNow(signalText,actionText)){return"checkout_start";}
if(looksLikeAddToCart(signalText,actionText)){if(looksLikeProductForm||/\/cart\/add(?:\.js)?(?:\/|$|\?)/.test(actionText)){return"add_to_cart";}}
var hasPasswordField=formData&&formData.field_count>0&&formIdentity&&formIdentity._hasPasswordField;if(hasPasswordField&&looksLikeRegistrationForm(signalText,actionText)){return"complete_registration";}
if(looksLikeRegistrationForm(signalText,actionText)){if(matchesAnyPattern(actionText,REG_URL_PATTERNS)){return"complete_registration";}}
var identityFields=formData&&formData.identity_fields?formData.identity_fields:{};var hasContactField=identityFields.email||identityFields.phone;if(hasContactField&&looksLikeLeadForm(signalText,actionText)){return"lead";}
return"form_submit";}
let contextSent=false;let behavioralSent=false;function sessionPayload(ended,reason){const durationMs=Date.now()-session.started_at;const pageHistory=Array.isArray(session.page_history)?session.page_history:[];const payload={session_id:session.id,visitor_id:attribution.gruid,pixel_id:pixelId||null,new_session:isNewSession,started_at:new Date(session.started_at).toISOString(),last_seen_at:new Date(session.last_seen).toISOString(),duration_ms:durationMs,page_views:session.page_views,landing_url:session.landing_url,last_page_url:session.last_page_url,entry_referrer:session.entry_referrer,last_referrer:sanitizeUrl(document.referrer)||null,ended:!!ended,reason:reason||null,attribution:Object.assign({},attribution),page_history:pageHistory,};if(!contextSent){payload.context=collectClientContext();contextSent=true;}else if(!behavioralSent&&_bhvHasSufficientData()){payload.context=collectClientContext();payload.context.behavioral=_bhvCollectFeatures();behavioralSent=true;}
if(CONFIG.inAppBrowser){payload.context=payload.context||{};payload.context.pixel_source="publisher_in_app_browser";}
return payload;}
function sendSessionUpdate(ended,reason,beacon){if(!CONFIG.sessionEndpoint)return;persistSession(session);const payload=sessionPayload(ended,reason);postJSON(CONFIG.sessionEndpoint,payload,beacon);}
function handleClick(event){let target=event.target;if(!target||target===document||target===window)return;let actionable=null;let current=target;for(let i=0;i<5&&current&&current!==document;i++){const tag=(current.tagName||"").toLowerCase();const role=current.getAttribute&&current.getAttribute("role");const type=(current.type||"").toLowerCase();const isInForm=!!(current.form||(current.closest&&current.closest("form")));if(isInForm){if(type==="submit"||(tag==="input"&&type==="submit")){return;}
if(tag==="button"&&type!=="button"){return;}}
if(tag==="a"||tag==="button"||role==="button"||role==="link"){actionable=current;break;}
current=current.parentElement;}
if(!actionable)return;const tagName=(actionable.tagName||"").toLowerCase();const rawHref=tagName==="a"?actionable.getAttribute("href"):actionable.getAttribute("data-href")||null;const metadata={tag:actionable.tagName||null,id:actionable.id||null,classes:typeof actionable.className==="string"?actionable.className:null,role:actionable.getAttribute&&actionable.getAttribute("role"),href:sanitizeUrl(rawHref),text:(actionable.innerText||actionable.textContent||"").trim().slice(0,120)||null,};const inferredEventType=inferClickEventType(actionable,metadata,rawHref);if(inferredEventType!=="click"){metadata.automatic_event=true;}
trackEvent(inferredEventType,metadata);}
function getFormIdentity(form){if(!form)return null;var hasPasswordField=false;try{var inputs=form.querySelectorAll("input");for(var i=0;i<inputs.length;i++){if((inputs[i].type||"").toLowerCase()==="password"){hasPasswordField=true;break;}}}catch(_){}
return{id:form.id||null,name:form.name||null,action:normalizedFormAction(form)||null,method:(form.method||"get").toLowerCase(),class:typeof form.className==="string"?form.className:null,_hasPasswordField:hasPasswordField,};}
function isSensitiveField(field){const type=(field.type||"").toLowerCase();const name=(field.name||"").toLowerCase();const id=(field.id||"").toLowerCase();const autocomplete=(field.autocomplete||field.getAttribute("autocomplete")||"").toLowerCase();const placeholder=(field.placeholder||"").toLowerCase();if(type==="password")return true;const ccPatterns=[/card/i,/cc[-_]?num/i,/credit/i,/cvv/i,/cvc/i,/security[-_]?code/i,/expir/i,/exp[-_]date/i,/ccv/i];if(autocomplete.indexOf("cc-")===0)return true;for(var i=0;i<ccPatterns.length;i++){if(ccPatterns[i].test(name)||ccPatterns[i].test(id)||ccPatterns[i].test(placeholder)){return true;}}
const idPatterns=[/ssn/i,/social[-_]?security/i,/passport/i,/national[-_]?id/i,/tax[-_]?id/i,/ein/i,/driver[-_]?licen[cs]e/i];for(var j=0;j<idPatterns.length;j++){if(idPatterns[j].test(name)||idPatterns[j].test(id)||idPatterns[j].test(placeholder)){return true;}}
const bankPatterns=[/routing[-_]?num/i,/account[-_]?num/i,/bank[-_]?account/i,/iban/i,/swift/i,/sort[-_]?code/i,/bsb/i];for(var k=0;k<bankPatterns.length;k++){if(bankPatterns[k].test(name)||bankPatterns[k].test(id)){return true;}}
const securityPatterns=[/pin/i,/secret/i,/token/i,/api[-_]?key/i,/access[-_]?code/i,/verification[-_]?code/i,/auth[-_]?code/i,/otp/i];for(var m=0;m<securityPatterns.length;m++){if(securityPatterns[m].test(name)||securityPatterns[m].test(id)){return true;}}
return false;}
function getFieldValue(field){const type=(field.type||"").toLowerCase();if(type==="checkbox"||type==="radio"){return field.checked;}
if(field.tagName==="SELECT"){if(field.multiple){const selected=[];for(let i=0;i<field.options.length;i++){if(field.options[i].selected){selected.push(field.options[i].value);}}
return selected.length>0?selected:null;}
return field.value||null;}
if(type==="file"){return field.files&&field.files.length>0?Array.from(field.files).map(f=>({name:f.name,size:f.size,type:f.type})):null;}
return field.value||null;}
function canonicalFieldKey(field){const name=(field.name||field.id||"").toLowerCase();if(!name)return null;if(name==="id"||name==="variant"||name==="variant_id")return"variant_id";if(name==="quantity"||name==="qty")return"quantity";if(name==="product_id"||name==="product-id")return"product_id";if(name==="form_type")return"form_type";if(name==="selling_plan"||name==="selling_plan_id")return"selling_plan_id";if(name==="sku")return"sku";if(name==="section-id"||name==="section_id")return"section_id";return null;}

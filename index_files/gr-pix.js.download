if(cookieGruid){attrib.gruid=cookieGruid;}
const firstSeen=attrib.first_seen||now;if(!attrib.gruid){attrib.gruid=attrib.gr_aid||uuid("gruid_");}
const mappedParams=[["grclid",params.get("grclid")],["grcpid",params.get("grcpid")],["grpuid",params.get("grpuid")],["gradid",params.get("gradid")],["grsig",params.get("grsig")],["graid",params.get("graid")],];const urlKeys=["utm_source","utm_medium","utm_campaign","utm_term","utm_content","utm_id","utm_source_platform","utm_creative_format","utm_marketing_tactic","gclid","dclid","gbraid","wbraid","msclkid","fbclid","ttclid","twclid","li_fat_id","rdt_cid","ScCid","epik","ko_click_id","adjust_tracker","adjust_campaign","branch_match_id","appsflyer_id",];const metaCookieKeys=["_fbp","_fbc"];let touched=false;for(let i=0;i<mappedParams.length;i+=1){const[key,value]=mappedParams[i];if(value){attrib[key]=value;touched=true;}}
for(let i=0;i<urlKeys.length;i+=1){const key=urlKeys[i];const value=params.get(key);if(value){attrib[key]=value;touched=true;}}
for(let i=0;i<metaCookieKeys.length;i+=1){const key=metaCookieKeys[i];const value=getCookie(key);if(value){attrib[key]=value;touched=true;}}

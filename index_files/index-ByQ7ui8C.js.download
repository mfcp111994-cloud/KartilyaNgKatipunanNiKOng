cted:"pages affected",affectedPages:"Affected pages",affectedRoutes:"Routes",andMore:"and {count} more...",fixWithAI:"Fix with AI",tryToFix:"Try to fix",diagnosedOn:"Diagnosed on",rediagnosis:"Diagnose",allIssues:"All Issues",showAll:"Show All",noIssues:"No Issues Found!",noIssuesDescription:"Great job! Your website passed all checks in this category.",publishHint:"Republish after making changes, then diagnose again to see updated results."},ose={all:"All",seo:"SEO",performance:"Performance",security:"Security",content:"Content",health:"Health"},ase={excellent:"Excellent",good:"Good",fair:"Fair",poor:"Needs Work"},ise={critical:"Danger",warning:"Warning",info:"Tip"},rse={noTitle:{title:"Missing Title Tag",description:"Pages without a title tag may not rank well in search results."},noDescription:{title:"Missing Meta Description",description:"Pages without a meta description may have lower click-through rates."},noH1Tag:{title:"Missing H1 Tag",description:"Pages should have exactly one H1 tag for better SEO."},titleTooLong:{title:"Title Too Long",description:"Title tags should be 50-60 characters for optimal display."},titleTooShort:{title:"Title Too Short",description:"Title tags should be at least 30 characters to be descriptive."},descriptionTooLong:{title:"Description Too Long",description:"Meta descriptions should be 150-160 characters for optimal display."},descriptionTooShort:{title:"Description Too Short",description:"Meta descriptions should be at least 70 characters to be effective."},duplicateTitle:{title:"Duplicate Title Tags",description:"Multiple pages have the same title tag, which can confuse search engines."},duplicateDescription:{title:"Duplicate Meta Descriptions",description:"Multiple pages have the same meta description."},highLoadingTime:{title:"High Loading Time",description:"Pages take too long to load, which affects user experience and SEO."},largePageSize:{title:"Large Page Size",description:"Pages are too large, which increases loading time."},renderBlocking:{title:"Render-Blocking Resources",description:"Resources are blocking the initial render of the page."},noContentEncoding:{title:"No Content Encoding",description:"Pages are not using compression (gzip/brotli)."},isHttp:{title:"Using HTTP Instead of HTTPS",description:"Pages are served over insecure HTTP connection."},httpsToHttpLinks:{title:"Mixed Content",description:"HTTPS pages contain links to HTTP resources."},noSsl:{title:"No SSL Certificate",description:"Your website does not have a valid SSL certificate."},noHttpsRedirect:{title:"No HTTPS Redirect",description:"HTTP requests are not being redirected to HTTPS."},duplicateContent:{title:"Duplicate Content",description:"Multiple pages have similar or identical content."},lowContentRate:{title:"Low Content Rate",description:"Pages have a high HTML-to-text ratio, indicating thin content."},lowCharacterCount:{title:"Low Character Count",description:"Pages have very little text content."},lowReadability:{title:"Low Readability",description:"Content is difficult to read and understand."},isBroken:{title:"Broken Pages",description:"Pages that return errors and cannot be accessed."},is4xxCode:{title:"4xx Errors",description:"Pages returning client error status codes."},is5xxCode:{title:"5xx Errors",description:"Pages returning server error status codes."},brokenLinks:{title:"Broken Links",description:"Pages contain links that lead to non-existent pages."},brokenResources:{title:"Broken Resources",description:"Pages reference resources (images, CSS, JS) that don't exist."},redirectLoop:{title:"Redirect Loop",description:"Pages are caught in a redirect loop."},noImageAlt:{title:"Images Missing Alt Text",description:"Images without alt text are not accessible and may hurt SEO."},noImageTitle:{title:"Images Missing Title",description:"Images without title attribute may provide less context."},noSitemap:{title:"Missing Sitemap",description:"Your website does not have a sitemap.xml file."},noRobotsTxt:{title:"Missing robots.txt",description:"Your website does not have a robots.txt file."},noHttp2:{title:"HTTP/2 Not Enabled",description:"Your server is not using HTTP/2 protocol. Enabling it can improve performance."},serverSignatureVisible:{title:"Server Signature Exposed",description:"Your server is exposing its signature in HTTP headers. Hiding this information can improve security."},noCanonicalization:{title:"Canonicalization Not Configured",description:"Your website may be accessible through multiple URL variations. Proper canonicalization helps consolidate SEO signals and avoid duplicate content issues."},nonIndexable:{title:"Non-Indexable Pages",reason:{noindex:"Pages are marked as noindex",canonical:"Pages have canonical pointing elsewhere",robots:"Pages are blocked by robots.txt"}}},lse={diagnosisTimeout:"Diagnosis timed out. Please try again.",requestFailed:"Request failed. Please try again.",invalidDomain:"Invalid domain format. Please check and try again.",noProjectId:"Project ID is not available. Please refresh the page or select a project from the sidebar."},cse={noTitle:"Please add a descriptive and SEO-friendly title tag to this page. The title should be between 50-60 characters, include relevant keywords, and accurately describe the page content.",noDescription:"Please add a meta description to this page. The description should be 150-160 characters, compelling, and include relevant keywords to improve click-through rates from search results.",noH1Tag:"Please add an H1 heading to this page. The H1 should clearly describe the main topic of the page and include relevant keywords for SEO.",titleTooLong:"The page title is too long and may be truncated in search results. Please shorten it to under 60 characters while keeping it descriptive and keyword-rich.",titleTooShort:"The page title is too short. Please expand it to 50-60 characters with a more descriptive title that includes relevant keywords.",duplicateTitleTag:"This page has a duplicate title tag. Please create a unique, descriptive title that differentiates this page from others on the site.",duplicateDescriptionTag:"This page has a duplicate meta description. Please write a unique description that specifically describes this page's content.",noSitemap:"Please create an XML sitemap for this website to help search engines discover and index all pages more efficiently.",noRobotsTxt:"Please create a robots.txt file to control how search engines crawl and index the website.",nonIndexable:"This page is not indexable by search engines. Please review and fix the indexability issues (check for noindex tags, canonical URLs, or redirect issues).",highLoadingTime:"This page loads slowly. Please optimize the page performance by: compressing images, minifying CSS/JS, enabling lazy loading, and reducing render-blocking resources.",largePageSize:"The page size is too large. Please reduce it by compressing images, minifying code, and removing unnecessary resources.",hasRenderBlockingResources:"There are render-blocking resources on this page. Please defer non-critical CSS/JS or load them asynchronously to improve page load speed.",noContentEncoding:"The server is not compressing content. Please enable gzip or brotli compression to reduce transfer sizes and improve load times.",largeResources:"There are large resource files (over 500KB) on this page. Please compress or optimize these files to improve loading performance.",isHttp:"This page is served over insecure HTTP. Please configure HTTPS and ensure all resources are loaded securely.",httpsToHttpLinks:"This HTTPS page contains links to HTTP resources (mixed content). Please update all resource URLs to use HTTPS.",noSsl:"This website does not have a valid SSL certificate. Please install and configure an SSL certificate for secure connections.",noHttpsRedirect:"HTTP requests are not being redirected to HTTPS. Please configure automatic HTTP to HTTPS redirects.",duplicateContent:"This page has content that is very similar to other pages. Please make the content unique or use canonical tags to indicate the preferred version.",lowContentRate:"This page has a low text-to-HTML ratio. Please add more meaningful text content to improve SEO value.",lowCharacterCount:"This page has very little text content (thin content). Please expand the content with valuable, relevant information.",lowReadabilityRate:"The content readability score is low. Please simplify the language, use shorter sentences, and break up long paragraphs.",isBroken:"This page is returning an error or is not accessible. Please fix the page to ensure it loads correctly.",is4xxCode:"This page is returning a 4xx error (like 404 Not Found). Please fix the page URL or create the missing content.",is5xxCode:"This page is returning a 5xx server error. Please investigate and fix the server-side issue.",brokenLinks:"This page contains broken links. Please fix or remove the links that lead to non-existent pages.",brokenResources:"This page has broken resources (images, scripts, stylesheets) that cannot be loaded. Please fix the resource URLs or remove the references.",redirectLoop:"This page is caught in a redirect loop. Please fix the redirect configuration to resolve the loop.",longRedirectChains:"There are long redirect chains (more than 3 hops). Please simplify the redirects to improve page load speed.",noImageAlt:"Images on this page are missing alt text. Please add descriptive alt attributes to all images for accessibility and SEO.",noImageTitle:"Images on this page are missing title attributes. Consider adding titles for additional context.",manyExternalLinks:"This site has a high number of external links. Please review them to ensure they are all relevant and trustworthy.",fallback:"Please fix the following issue: {title}. {description}",onPage:'On the page "{page}": {prompt}',onPages:"On the following pages ({pages}): {prompt}"},dse={$comment:Yne,pageTitle:Zne,permission:Xne,unpublished:Jne,start:ese,loading:tse,error:nse,re
ed",kz={name:"GitHub",description:"Sync your project code with a GitHub repository for version control and team collaboration."},Tz={name:"Supabase",description:"Connect for user authentication, database management, and backend services integration."},Ez={name:"Stripe",description:"Securely accept payments from your users, sell products or services, and manage transactions."},xz={name:"Shopify",description:"Showcase your Shopify store's products, let visitors browse items, and make purchases onsite."},Dz={name:"Calendly",description:"Visitors can easily book meetings or appointments with you directly from your site."},Rz={name:"Mailchimp",description:"Create, send, and automate email campaigns to grow your subscriber base and engage customers."},Lz={name:"Google Analytics",description:"Monitor visitor behavior, sources, and performance of your Readdy website."},Oz={name:"Readdy Agent",description:"AI chat/voice agent for customer service, lead collection, and appointment scheduling."},Mz={name:"Readdy Booking",description:"Quickly select a date and time to book an appointment."},Nz={name:"Resend",description:"Send professional branded emails from your own domain with high deliverability.",notPublishedHint:"Send branded emails from your domain. Publish your site first to get started."},jz={name:"Readdy Backend",description:"Connect database and edge functions to power your application's backend."},Fz={$comment:Iz,integrations:Az,connected:Pz,github:kz,supabase:Tz,stripe:Ez,shopify:xz,calendly:Dz,mailchimp:Rz,googleAnalytic:Lz,readdyAgent:Oz,readdyBooking:Mz,resend:Nz,readdyBackend:jz},Bz="All keys in this file are prefixed with: integration.github",Qz={connected:"Connected to GitHub",redirecting:"Redirecting…"},Uz={connect:{title:"Connect GitHub",desc1:"GitHub is the world's leading platform for version control and code collaboration. By connecting your GitHub account, you can sync your Readdy project with a GitHub repository.",desc2:"Push your latest project code to GitHub at any time, or pull code from GitHub to create a new version in Readdy — keeping your project in sync with your development workflow.",desc3:`Click "Connect GitHub" to link your account. Don't have a repository yet? You can create one in the next step.`,learnMore:"Learn more in docs",button:"Connect GitHub",ownerOnly:"Only owner can connect GitHub",refresh:"Refresh"},connecting:{title:"Connecting to GitHub…",description:"A GitHub window has been opened. Please complete the installation there and return to Readdy.",cancel:"Cancel"},createRepo:{statusBadge:"GitHub connected",title:"Create Repository",subtitle:"Create a new private repository to sync changes",description:"Authorization and installation are complete. Next, create a repository for this project.",orgLabel:"GitHub Organization",account:"Account",create:"Create Repository",creating:"Creating repository…",dismiss:"Cancel",addOrg:"Add GitHub Organization"},connected:{statusBadge:"Connected",connectedInfo:"Connected Info",account:"Account",organization:"Organization",disconnectAccount:"Disconnect account",project:"Project",projectDesc:"Connect your project to your GitHub in a 2-way sync",repoLabel:"Repository",disconnect:"Disconnect",disconnectRepoConfirm:{title:"Disconnect repository?",tip1:"The GitHub repository will not be deleted.",tip2:"If you reconnect later, a new repository will be created for this project.",cancel:"Cancel",confirm:"Disconnect",disconnecting:"Disconnecting"},clone:"Clone",cloneDesc:"Copy this repository to your local environment",cloneHttps:"HTTPS",cloneSsh:"SSH",cloneCli:"GitHub CLI",copied:"Copied!",copy:"Copy",syncActions:"Sync actions",push:"Push to GitHub",pull:"Pull from GitHub",pushing:"Pushing…",pulling:"Pulling…",lastSynced:"Last synced",synced:"Synced",pushDisabledGenerating:"A new version is being generated…",pushDisabledSyncing:"Sync in progress…"},error:{oauthExpired:{title:"GitHub authorization has expired",description:"Please reauthorize your GitHub account",action:"Reconnect GitHub"},appRemoved:{title:"GitHub app has been removed",description:"The Readdy GitHub App is no longer installed on your account or organization. Please reinstall.",action:"Reinstall GitHub App"},appError:{title:"GitHub App is unavailable",description:"The Readdy GitHub App has been removed or suspended on your account or organization. Please reinstall or restore access.",action:"Restore GitHub Access"},repoError:{title:"Repository is unavailable",description:"The connected repository may have been deleted or access has been revoked. Disconnect and create a new repository to continue syncing.",action:"Disconnect"},organizationError:{title:"Organization access is restricted",description:"The Readdy GitHub App can't access this organization. Please contact your organization admin to approve access.",action:"Reconnect GitHub"},orgBlocked:{title:"Organization access blocked",description:"The Readdy GitHub App can’t access this organization. An admin may need to approve access or complete SSO.",action:"Reconnect GitHub"},repoDeleted:{title:"Repository not found",description:"Disconnect and create a new repository to continue syncing.",action:"Disconnect"},repoNoAccess:{title:"Repository access denied",description:"Readdy no longer has access to this repository. Check your GitHub App permissions.",action:"Open GitHub Settings"},memberRemoved:{title:"GitHub App has been removed",description:"The Readdy GitHub App is no longer installed on your account or organization. Please reinstall.",action:"Reinstall GitHub App"}}},Vz={refreshed:"Refreshed",repoCreated:"Repository created and synced",repoCreateFailed:"Failed to create repository. Please try again.",pushed:"Pushed to GitHub",pushFailed:"Push failed. Please try again.",pulled:"Pulled from GitHub",pullFailed:"Pull failed. Please try again.",syncInProgress:"Sync in progress. Please try again in 10 minutes.",repoDisconnected:"Repository disconnected.",repoDisconnectFailed:"Failed to disconnect. Please try a
  // 存储收集到的错误
  const errorList = [];

  // 根据错误类型生成提示词
  // 阻止 eslint 监测
  /* eslint-disable */
  const getPromptByErrorType = (errorInfo) => {
    const basePrompt = \`我遇到了以下 JavaScript 错误，请帮我分析并修复：\\n\\n错误信息：\${errorInfo.message}\\n错误类型：\${errorInfo.errorType}\\n错误位置：第 \${errorInfo.lineNumber} 行，第 \${errorInfo.columnNumber} 列\\n\`;

    let specificPrompt = '';
    switch (errorInfo.errorType) {
      case 'ReferenceError':
        specificPrompt = \`\\n这是一个引用错误，看起来是访问了未定义的变量或对象。\\n请帮我：\\n1. 检查变量是否已定义\\n2. 检查变量名是否拼写正确\\n3. 检查变量的作用域是否正确\\n4. 提供修复后的代码\`;
        break;

      case 'TypeError':
        specificPrompt = \`\\n这是一个类型错误，可能是对错误类型的值进行了操作。\\n请帮我：\\n1. 检查变量的类型是否正确\\n2. 检查是否对 null 或 undefined 进行了操作\\n3. 检查方法调用是否正确\\n4. 提供修复后的代码\`;
        break;

      case 'SyntaxError':
        specificPrompt = \`\\n这是一个语法错误，代码可能存在语法问题。\\n请帮我：\\n1. 检查代码语法是否正确\\n2. 检查括号、引号是否配对\\n3. 检查语句是否完整\\n4. 提供修复后的代码\`;
        break;

      case 'RangeError':
        specificPrompt = \`\\n这是一个范围错误，可能是数组越界或数值超出范围。\\n请帮我：\\n1. 检查数组索引是否越界\\n2. 检查数值是否在有效范围内\\n3. 检查递归是否可能导致栈溢出\\n4. 提供修复后的代码\`;
        break;

      default:
        specificPrompt = \`\\n请帮我：\\n1. 分析这个错误的原因\\n2. 提供修复方案\\n3. 解释修复后的代码如何避免类似错误\`;
    }

    return basePrompt + specificPrompt;
  };

  // 监听页面 error 事件
  window.addEventListener(
    'error',
    (event) => {
      const errorInfo = {
        message: event.message,
        type: event.error ? event.error.name : 'UnknownError',
        lineNumber: event.lineno,
        columnNumber: event.colno
      };

      // errorInfo.prompt = getPromptByErrorType(errorInfo);
      errorList.push(errorInfo);
    },
    true
  );

  const reportError = () => {
    setTimeout(() => {
      if (errorList.length > 0) {
        window.parent.postMessage(
          {
            type: 'iframe-errors',
            errors: errorList,
            recordId: window.frameElement?.getAttribute('data-record-id')
          },
          '*'
        );
      }
    }, 1000);
  };
  if (document.readyState === 'complete') {
    reportError();
  } else {
    window.addEventListener('load', () => {
      reportError();
    });
  }
})();
